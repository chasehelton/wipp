{
  "name": "wipp",
  "version": "0.1.0",
  "description": "AI coding assistant powered by GitHub Copilot SDK, controlled via Discord, running on Raspberry Pi",
  "type": "module",
  "main": "dist/daemon.js",
  "bin": {
    "wipp": "dist/daemon.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/daemon.ts",
    "start": "node dist/daemon.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "better-sqlite3": "^11.10.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "author": "Chase Helton",
  "license": "MIT"
}
